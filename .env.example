# Copy to .env.local and fill in. NEVER commit real secrets.
# Only NEXT_PUBLIC_* values are exposed to the browser.

# --- Core ---
NODE_ENV=development

# --- Auth (Auth.js / NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Demo credentials provider (replace with a real user lookup in src/auth.ts)
ADMIN_USER=admin
ADMIN_PASSWORD=

# --- Postgres (lib/db.ts) ---
# App boots without this; db calls just fail-soft until it's set.
DATABASE_URL=postgres://user:pass@localhost:5432/app

# --- Redis (lib/redis.ts) ---
# Optional. Missing Redis degrades gracefully (in-memory fallbacks).
REDIS_URL=redis://localhost:6379

# --- Email (lib/email.ts) — example transactional provider (Resend) ---
# Missing key => emails are logged instead of sent (no-op in dev).
RESEND_API_KEY=
EMAIL_FROM="App <noreply@example.com>"

# --- Alerts (lib/alerts.ts) ---
# Missing webhook => critical-path alerts are logged instead of posted.
SLACK_WEBHOOK_URL=

# --- Example third-party integration (lib/example-service.ts) ---
EXAMPLE_SERVICE_BASE_URL=
EXAMPLE_SERVICE_API_KEY=
